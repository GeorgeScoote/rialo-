# ChainSure Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Network Configuration
# =============================================================================

# Rialo network: devnet | testnet | mainnet
VITE_RIALO_NETWORK=devnet

# Program ID (smart contract address)
VITE_PROGRAM_ID=ChainSure1111111111111111111111111111111111

# =============================================================================
# API Keys
# =============================================================================

# AirLabs API key for flight data
# Get your key at: https://airlabs.co/
VITE_AIRLABS_API_KEY=your_api_key_here

# =============================================================================
# Feature Flags
# =============================================================================

# Enable debug mode
VITE_DEBUG=false

# Enable analytics
VITE_ANALYTICS_ENABLED=false

# =============================================================================
# Optional: Analytics & Monitoring
# =============================================================================

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=

# Google Analytics ID
# VITE_GA_ID=
